<odoo>

    <record id="module_category_hospital" model="ir.module.category">
        <field name="name">hospital management</field>
        <field name="description">Helps manage doctors and patient slots.</field>
        <field name="sequence">10</field>
    </record>

    <!-- in odoo 19 PRIVILEGE MODEL IS ADDED AS LINK TABLE-->
    <record id="privilege_hospital" model="res.groups.privilege">
        <field name="name">hospital management</field>
        <field name="category_id" ref="module_category_hospital"/>
    </record>



    <record id="group_hospital_patient" model="res.groups">
        <field name="name">Patient</field>
        <field name="privilege_id" ref="privilege_hospital"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hospital_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="privilege_id" ref="privilege_hospital"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_hospital_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_hospital"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>





