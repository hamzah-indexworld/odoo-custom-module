<odoo>

    <record id="view_hospital_slot_list" model="ir.ui.view">
        <field name="name">hospital.slot.list</field>
        <field name="model">hospital.slot</field>
        <field name="arch" type="xml">
            <list>
                <field name="doctor_id"/>
                <field name="slot_date"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time"  widget="float_time"/>
                <field name="patient_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>


    <record id="view_hospital_slot_form" model="ir.ui.view">
        <field name="name">hospital.slot.form</field>
        <field name="model">hospital.slot</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="doctor_id"/>
                        <field name="slot_date"/>
                        <field name="start_time" widget="float_time"/>
                        <field name="end_time"  widget="float_time"/>
                        <field name="patient_id"/>
                        <field name="status"/>
                    </group>
                </sheet>

            </form>
        </field>
    </record>













</odoo>