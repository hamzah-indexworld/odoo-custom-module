<odoo>

    <record id="view_hospital_staff_doctor_list" model="ir.ui.view">
        <field name="name">hospital.staff.doctor.list</field>
        <field name="model">hospital.staff</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="specialization"/>
                <field name="phone"/>
            </list>
        </field>
    </record>


    <record id="view_hospital_staff_doctor_form" model="ir.ui.view">
        <field name="name">hospital.staff.doctor.form</field>
        <field name="model">hospital.staff</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(action_hospital_slot_wizard)d"
                            type="action"
                            string="Generate Slots"
                            class="btn-primary"
                            context="{'default_doctor_id': id}"
                    />
                </header>

                <sheet>
                    <group>
                        <field name="name" />
                        <field name="specialization"/>
                        <field name="phone"/>
                    </group>

                    <separator />

                    <notebook>
                        <page string="Your Slots">
                            <field name="slot_ids" >
                                <list editable="bottom" edit="0" create="0" delete="0">
                                    <field name="doctor_id"/>
                                    <field name="specialization" />
                                    <field name="slot_date"  />
                                    <field name="start_time" widget="float_time" />
                                    <field name="end_time" widget="float_time" />
                                    <field name="patient_id"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>






</odoo>