<odoo>

    <record id="action_hospital_doctor_menu" model="ir.actions.act_window">
        <field name="name">hospital doctor</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hospital_patient_menu" model="ir.actions.act_window">
        <field name="name">hospital patient</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hospital_slot_menu" model="ir.actions.act_window">
        <field name="name">hospital slot</field>
        <field name="res_model">hospital.slot</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_hospital_weekday_menu" model="ir.actions.act_window">
        <field name="name">hospital weekday</field>
        <field name="res_model">hospital.weekday</field>
        <field name="view_mode">list,form</field>
    </record>





    <record id="action_hospital_slot_wizard" model="ir.actions.act_window">
        <field name="name">Generate Slots</field>
        <field name="res_model">hospital.slot.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>



<!--    staff doctor -->
    <record id="action_hospital_staff_doctor_menu" model="ir.actions.act_window">
        <field name="name">hospital staff doctor</field>
        <field name="res_model">hospital.staff</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('role','=','doctor')]</field>
        <field name="context">{'default_role':'doctor'}</field>
        <field name="view_ids" eval="[
            (5,0,0),
            (0,0, {'view_mode': 'list', 'view_id': ref('view_hospital_staff_doctor_list') }),
            (0,0, {'view_mode': 'form', 'view_id': ref('view_hospital_staff_doctor_form') }),
        ]" />
    </record>


    <!--    staff nurse -->
    <record id="action_hospital_staff_nurse_menu" model="ir.actions.act_window">
        <field name="name">hospital staff nurse</field>
        <field name="res_model">hospital.staff</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('role','=','nurse')]</field>
        <field name="context">{'default_role':'nurse'}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_hospital_staff_nurse_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_hospital_staff_nurse_form')})
        ]"/>
    </record>




</odoo>