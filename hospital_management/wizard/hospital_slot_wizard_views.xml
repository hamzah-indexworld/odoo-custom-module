<odoo>




     <record id="view_hospital_slot_wizard_form" model="ir.ui.view">
        <field name="name">hospital.slot.wizard.form</field>
        <field name="model">hospital.slot.wizard</field>
        <field name="arch" type="xml">
            <form string="Generate Slots">
                <sheet>
                    <group>
                        <field name="doctor_id"/>

                        <field name="weekday_ids" widget="many2many_tags"/>

                        <field name="start_time" widget="float_time"/>
                        <field name="end_time" widget="float_time"/>
                        <field name="slot_duration"/>
                    </group>
                </sheet>

                <footer>
                    <button name="action_generate_slots"
                            string="Generate Slots"
                            type="object"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>










</odoo>