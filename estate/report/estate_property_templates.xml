
<odoo>


<template id="report_property_offers_template">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="property">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>
                        <span t-field="property.name"/>
                    </h2>
                    <div class="row mt-3 mb-4">
                        <div class="col-6">
                            <strong>Expected Price: </strong>
                            <span t-field="property.expected_price"/>
                        </div>
                        <div class="col-6">
                            <strong>Status: </strong>
                            <span t-field="property.state"/>
                        </div>
                    </div>

                    <hr/>

                    <h3>Offers Received</h3>

                    <t t-set="offers" t-value="property.mapped('offer_ids')"/>

                    <div t-if="not offers" class="alert alert-info mt-3">
                        No offers have been placed on this property yet.
                    </div>

                    <table t-if="offers" class="table table-sm table-striped mt-3">
                        <thead>
                            <tr>
                                <th>Bidder</th>
                                <th class="text-end">Price</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="offers" t-as="offer">
                                <td>
                                    <span t-field="offer.buyer_id.name"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="offer.price"/>
                                </td>
                                <td class="text-center">
                                    <span t-field="offer.status"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>

                </div>
            </t>
        </t>
    </t>
</template>



</odoo>