
<odoo>



<record id="module_category_real_estate" model="ir.module.category">
    <field name="name">Real Estate</field>
</record>


<!-- in odoo 19 PRIVILEGE MODEL IS ADDED AS LINK TABLE-->
<record id="privilege_estate_management" model="res.groups.privilege">
    <field name="name">Real Estate Management</field>
    <field name="category_id" ref="module_category_real_estate"/>
</record>


<!-- CREATING CUSTOM USER GROUPS BESIDE BASE.GROUP_USER , BCZ GROUP_USER(INTERNAL USER) THAT HAS ACCESS TO BACKEND -->

<record id="group_estate_user" model="res.groups">
    <field name="name">User</field>
    <field name="privilege_id" ref="privilege_estate_management"/>
    <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
</record>

<record id="group_estate_manager" model="res.groups">
    <field name="name">Administrator</field>
    <field name="privilege_id" ref="privilege_estate_management"/>
    <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
</record>





<!--ASSIGNING RECORD RULES TO MY CUSTOM USER GROUPS    -->

<record id="rule_estate_property_agent" model="ir.rule">
    <field name="name">Personal Properties Only</field>
    <field name="model_id" ref="model_estate_property"/>
    <field name="groups" eval="[(4, ref('group_estate_user'))]"/>
    <field name="domain_force">[('salesperson_id', '=', user.id)]</field>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="True"/>
    <field name="perm_create" eval="True"/>
    <field name="perm_unlink" eval="True"/>
</record>

<record id="rule_estate_property_manager" model="ir.rule">
    <field name="name">Manager: See All Properties</field>
    <field name="model_id" ref="model_estate_property"/>
    <field name="groups" eval="[(4, ref('group_estate_manager'))]"/>
    <field name="domain_force">[(1, '=', 1)]</field>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="True"/>
    <field name="perm_create" eval="True"/>
    <field name="perm_unlink" eval="True"/>
</record>



</odoo>
